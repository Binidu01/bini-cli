{
  "name": "create-bini-app",
  "type": "module",
  "version": "10.0.0",
  "description": "Build full-stack React apps for web, desktop, and mobile — from one codebase.",
  "keywords": [
    "bini",
    "bini.js",
    "binijs",
    "create-bini-app",
    "react",
    "react framework",
    "full-stack framework",
    "vite",
    "rolldown",
