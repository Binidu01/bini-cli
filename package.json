    "linux",
    "hono",
    "cli",
    "scaffolder",
    "project generator",
    "oxlint",
    "oxfmt"
  ],
  "main": "dist/index.js",
  "bin": {
    "create-bini-app": "dist/index.js",
    "bini": "dist/index.js",
    "binijs": "dist/index.js"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node dist/index.js --version",
    "prepublishOnly": "npm run typecheck && npm run build && node dist/index.js --version",
    "clean": "rm -rf dist"
  },
  "homepage": "https://bini.js.org",
  "repository": {
